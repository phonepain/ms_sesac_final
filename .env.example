# Azure Cosmos DB (Gremlin)
COSMOS_ENDPOINT=wss://your-account.gremlin.cosmos.azure.com:443/
COSMOS_KEY=
COSMOS_DATABASE=conticheck
COSMOS_GRAPH_WS=ws-graph
COSMOS_GRAPH_SC=sc-graph

# Azure AI Search
AZURE_SEARCH_ENDPOINT=https://your-search.search.windows.net
AZURE_SEARCH_KEY=
AZURE_SEARCH_INDEX=conticheck-index

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_DEPLOYMENT_EXTRACTION=gpt-5-nano

# Anthropic
ANTHROPIC_API_KEY=

# 개발 모드 (로컬 테스트 시 True)
USE_LOCAL_GRAPH=True
USE_MOCK_EXTRACTION=True
USE_MOCK_SEARCH=True

# 서버
HOST=0.0.0.0
PORT=8000